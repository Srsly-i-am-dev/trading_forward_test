WEBHOOK_SHARED_TOKEN=replace-with-strong-token
EXECUTOR_MODE=real
DB_PATH=logs/trades.db
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
LOG_LEVEL=INFO

DEFAULT_VOLUME_UNITS=1000
DEFAULT_RISK=1.0

CTRADER_CLIENT_ID=your-client-id
CTRADER_CLIENT_SECRET=your-client-secret
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
CTRADER_ACCOUNT_ID=your-account-id
CTRADER_ENVIRONMENT=demo
CTRADER_TOKEN_URL=https://openapi.ctrader.com/apps/token
CTRADER_ORDER_URL=https://openapi.ctrader.com/trade
CTRADER_SYMBOL_MAP={"EURUSD":"EURUSD","GBPUSD":"GBPUSD","USDJPY":"USDJPY"}

REQUEST_TIMEOUT_SECONDS=10
MAX_EXECUTION_RETRIES=2
